# Google Cloud Service Account Credentials
# Generate these in the Google Cloud Console (IAM & Admin > Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Drive Configuration
# Create a folder in Google Drive and share it with the service account email above.
# The ID is the last part of the folder URL.
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Google Sheets Configuration
# Create a Google Sheet and share it with the service account email above.
# The ID is found in the URL: /d/[SHEET_ID]/edit
GOOGLE_SHEET_ID=your-google-sheet-id

# Email Configuration (e.g., using Resend or Gmail SMTP)
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your-api-key
EMAIL_FROM=reports@yourdomain.com
EMAIL_TO=admin@yourdomain.com

# Alert email layout: classic | table | card
EMAIL_TEMPLATE=table
# Create a token at: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN="your_personal_access_token_here"
GITHUB_REPO_OWNER="your_github_username_or_org"
GITHUB_REPO_NAME="your_repository_name"